# Notion API Configuration
# API Key from https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_your_key_here

# Main page ID (千萬經紀人之路！)
NOTION_MAIN_PAGE_ID=32156ff9a8598091916ed853c177fa0f

# Database IDs - visit /setup page to auto-discover
NOTION_BUYER_DB_ID=
NOTION_TODO_DB_ID=
NOTION_TRACKING_DB_ID=
NOTION_WEEKLY_DB_ID=32156ff9a8598105bf8ddc4aa3089516
NOTION_STRATEGY_DB_ID=32156ff9a8598141a4a7cae9821e148c
NOTION_AI_IDEAS_DB_ID=
NOTION_GOAL_DB_ID=

# Phase 2 (2026-05-12) — 新 schema 三層結構 DB
# 跟舊 BUYER/TRACKING DB 並存、雙軌期 ≥ 2 週
NOTION_PERSON_DB_ID=35e56ff9-a859-8186-a666-cec33216dc6d
NOTION_PROPERTY_DB_ID=35e56ff9-a859-81d4-8e5e-df99b5781504
NOTION_BUYER_NEED_DB_ID=35e56ff9-a859-81f6-a34b-f89c55bf32c5

# MBA Step 2 - 策略任務清單/週 DB (route 已 hardcode fallback，可不填)
NOTION_WEEKLY_TASKS_DB_ID=e7a56ff9a8598267801e811313635414

# MBA Step 3 - /m/* 子站認證
MBA_PASSWORD=your_mba_password
MBA_AUTH_SECRET=your_mba_secret_random_string

# MBA Step 4 - Google Calendar (OAuth2 + refresh token) & Geocoding
# OAuth client 在 Google Cloud Console → APIs & Services → Credentials 建立
# refresh token 透過 OAuth Playground 一次性授權取得
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Google Maps Geocoding API key（可重用 n8n 常數初始化節點那把）
GMAPS_API_KEY=

# B6 微調 - i智慧 列印頁 empNo（員工編號，6 字元）
# 未設定時 client 端 fallback 成 'C30419'
NEXT_PUBLIC_YCUT_EMP_NO=C30419
